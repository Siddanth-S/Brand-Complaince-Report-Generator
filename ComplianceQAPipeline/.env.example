# =============================================================================
# BRAND GUARDIAN AI — ENVIRONMENT CONFIGURATION
# =============================================================================
# HOW TO FIND EACH VALUE:
#   Azure Portal → search the service name in the top bar → go to its Overview
#   or Keys & Endpoint page as noted below.
# =============================================================================


# -----------------------------------------------------------------------------
# GOOGLE GEMINI  (LLM + Embeddings)
# Get your free API key at: aistudio.google.com → Get API Key
# No credit card required — works on student accounts
# -----------------------------------------------------------------------------

# aistudio.google.com → Get API Key → Create API key
GOOGLE_API_KEY=""


# -----------------------------------------------------------------------------
# AZURE AI SEARCH  (Vector Store / RAG Knowledge Base)
# Portal path: Azure AI Search resource → Overview / Keys
# -----------------------------------------------------------------------------

# Portal: Azure AI Search resource → Overview → Url
# Example: https://your-search-name.search.windows.net
AZURE_SEARCH_ENDPOINT=""

# Portal: Azure AI Search resource → Settings → Keys → Primary admin key
AZURE_SEARCH_API_KEY=""

# The name of the index you created (or will create) in Azure AI Search
# Example: "brand-guardian-index"
AZURE_SEARCH_INDEX_NAME=""


# -----------------------------------------------------------------------------
# AZURE VIDEO INDEXER
# Portal path: Azure Video Indexer resource → Overview
# Also see: vi.microsoft.com → your account → Account settings
# -----------------------------------------------------------------------------

# Portal: Video Indexer resource → Overview → Account ID
AZURE_VI_ACCOUNT_ID=""

# The Azure region your Video Indexer is deployed in
# Example: "eastus", "westeurope", "trial" (for free trial accounts)
AZURE_VI_LOCATION=""

# The name of your Video Indexer resource in Azure
# Example: "project-brand-guardian-001"
AZURE_VI_NAME=""

# Portal: Subscriptions → your subscription → Subscription ID
AZURE_SUBSCRIPTION_ID=""

# Portal: Video Indexer resource → Overview → Resource group
AZURE_RESOURCE_GROUP=""


# -----------------------------------------------------------------------------
# AZURE STORAGE  (used for video artifact storage — future feature)
# Portal path: Storage Account resource → Security + networking → Access keys
# -----------------------------------------------------------------------------

# Portal: Storage Account → Access keys → Connection string (key1)
AZURE_STORAGE_CONNECTION_STRING=""


# -----------------------------------------------------------------------------
# AZURE MONITOR / APPLICATION INSIGHTS  (Observability / Telemetry)
# Portal path: Application Insights resource → Overview → Connection String
# -----------------------------------------------------------------------------

# Portal: Application Insights → Overview → Connection String
# Example: InstrumentationKey=abc...;IngestionEndpoint=https://...
APPLICATIONINSIGHTS_CONNECTION_STRING=""


# -----------------------------------------------------------------------------
# LANGSMITH  (LLM Tracing — optional but recommended)
# Sign up at: smith.langchain.com → Settings → API Keys
# -----------------------------------------------------------------------------

# Enable LangSmith tracing: set to "true" to turn on, "false" to disable
LANGCHAIN_TRACING_V2=true

# LangSmith API endpoint — leave as-is unless self-hosting
LANGCHAIN_ENDPOINT=""

# smith.langchain.com → Settings → API Keys → Create API Key
LANGCHAIN_API_KEY=""

# The project name to group traces under in LangSmith
# Example: "brand-guardian-dev"
LANGCHAIN_PROJECT=""

